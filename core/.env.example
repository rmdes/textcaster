TEXTCASTER_TOKEN=change-me
TEXTCASTER_DB=./data/textcaster.db
TEXTCASTER_PORT=8787
TEXTCASTER_POLL_SECONDS=60

# Required. Generate with: openssl rand -hex 32
TEXTCASTER_AUTH_SECRET=change-me

# Optional — defaults shown. Must match the web app's public origin, or
# every session-carrying auth request 403s (better-auth CSRF check).
# TEXTCASTER_WEB_ORIGIN=http://localhost:5173

# Optional — default shown. Idle anonymous accounts are swept hourly once
# they exceed this many days.
# TEXTCASTER_ANON_TTL_DAYS=7
